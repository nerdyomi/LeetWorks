      "source": [
        "class Solution(object):\n",
        "    def addDigits(self, num):\n",
        "        \"\"\"\n",
        "        :type num: int\n",
        "        :rtype: int\n",
        "        \"\"\"\n",
        "        while len(str(num)) > 1:\n",
        "            num = sum([int(i) for i in str(num)])\n",
        "        return num"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "A=Solution()\n",
        "A.addDigits(38)"
      ],
