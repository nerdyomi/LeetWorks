      "source": [
        "class Solution(object):\n",
        "    def containsDuplicate(self, nums):\n",
        "        \"\"\"\n",
        "        :type nums: List[int]\n",
        "        :rtype: bool\n",
        "        \"\"\"\n",
        "        return len(nums)!=len(set(nums))"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "a=Solution()\n",
