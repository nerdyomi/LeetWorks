        "Find the length of the last word"
      ],
      "metadata": {
        "id": "WGnMQLjtXsQg"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class Solution(object):\n",
        "    def lengthOfLastWord(self, s):\n",
        "        \"\"\"\n",
        "        :type s: str\n",
        "        :rtype: int\n",
        "        \"\"\"\n",
        "        return len(s.split()[-1])\n",
        ""
      ],
      "metadata": {
        "id": "XwUAKhENXqnn"
      },
      "execution_count": 7,
      "outputs": []
    },
